# Supabase (project-specific — auto-populated by `vercel env pull` after start-project)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Clerk (project-specific — auto-populated by `vercel env pull`)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk satellite mode (PRODUCTION cutover only — foundr.money is a satellite of
# the foundr.company primary instance). Leave unset for local dev / the dev
# instance. When enabled, use the foundr.company instance pk_live/sk_live above.
NEXT_PUBLIC_CLERK_IS_SATELLITE=
NEXT_PUBLIC_CLERK_PRIMARY_URL=https://foundr.company
NEXT_PUBLIC_CLERK_SATELLITE_DOMAIN=foundr.money
